{
  "name": "workflowy-github-sync",
  "version": "1.0.0",
  "description": "Create a Workflowy task automatically whenever a GitHub issue is opened.",
  "type": "module",
  "author": "Uri Goldshtein",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Urigo/workflowy-automation.git"
  },
  "homepage": "https://github.com/Urigo/workflowy-automation#readme",
  "bugs": {
    "url": "https://github.com/Urigo/workflowy-automation/issues"
  },
  "bin": {
    "workflowy-github-sync": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "once": "npm run build && node dist/index.js --once",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^7.0.2"
  },
  "license": "MIT"
}
