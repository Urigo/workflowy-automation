# GitHub token with read access to the repos you watch
# (fine-grained token with Issues: Read-only is enough)
# https://github.com/settings/tokens
GITHUB_TOKEN=

# API key from https://workflowy.com/api-key
WORKFLOWY_API_KEY=

# Comma-separated list of repos to watch
GITHUB_REPOS=my-org/api, my-org/web

# Optional — where new tasks land ("inbox" or a bullet's node id)
#WORKFLOWY_PARENT_ID=inbox

# Optional — layout mode for created tasks
#WORKFLOWY_LAYOUT_MODE=todo

# Optional — minutes between polls in continuous mode
#POLL_INTERVAL_MINUTES=5

# Optional — set to true before the first run to import existing open issues
#BACKFILL_EXISTING=false
