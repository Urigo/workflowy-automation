{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    // Type-check only — Node runs the .ts source directly via type stripping.
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    // Fail the check on any syntax Node's type stripping can't erase
    // (enums, namespaces, parameter properties, etc.).
    "erasableSyntaxOnly": true
  },
  "include": ["src/**/*.ts"]
}
